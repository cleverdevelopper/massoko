{
  "name": "masoko",
  "main": "index.js",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "android:both": "adb -s 127.0.0.1:5557 shell monkey -p com.anonymous.masoko -c android.intent.category.LAUNCHER 1 & adb -s 127.0.0.1:7555 shell monkey -p com.anonymous.masoko -c android.intent.category.LAUNCHER 1",
    "android:dev": "adb -s 127.0.0.1:5557 reverse tcp:8081 tcp:8081 && adb -s 127.0.0.1:7555 reverse tcp:8081 tcp:8081 && npm run android:both",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint"
  },
